# ── Plane CE Production Environment ──────────────────────────────────
# Copy to .env and fill in real values before deploying.
# This file is checked into source control; NEVER put real secrets here.

# Database
POSTGRES_USER="plane"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="plane"
PGDATA="/var/lib/postgresql/data"

# Redis
REDIS_HOST="plane-redis"
REDIS_PORT="6379"

# RabbitMQ
RABBITMQ_HOST="plane-mq"
RABBITMQ_PORT="5672"
RABBITMQ_USER="plane"
RABBITMQ_PASSWORD="CHANGE_ME"
RABBITMQ_VHOST="plane"

# Listener ports (proxy)
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443

# Object storage (Minio, bundled)
AWS_REGION=""
AWS_ACCESS_KEY_ID="CHANGE_ME"
AWS_SECRET_ACCESS_KEY="CHANGE_ME"
AWS_S3_ENDPOINT_URL="http://plane-minio:9000"
AWS_S3_BUCKET_NAME="uploads"
FILE_SIZE_LIMIT=5242880
USE_MINIO=1

# SSL (optional – leave blank to disable)
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TRUSTED_PROXIES=0.0.0.0/0
SITE_ADDRESS=:80
CERT_EMAIL=
CERT_ACME_DNS=
MINIO_ENDPOINT_SSL=0

# API rate limit
API_KEY_RATE_LIMIT="60/minute"
